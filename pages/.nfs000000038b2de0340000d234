<script>
    // 联通点：PHP 传回的数据
    const rawData = <?php echo json_encode($output_data); ?>;
    const container = document.getElementById('cardsContainer');

    function renderCards(data) {
        if (!container) return;
        container.innerHTML = data.map(item => `
            <div class="protein-card">
                <strong>${item.accession_id}</strong> 
                <span style="color: #666; font-size: 0.9em;">(Length: ${item.seq_length} aa)</span><br>
                <small style="color: #444;">${item.description}</small>
                <div class="seq-text">${item.sequence.substring(0, 120)}...</div>
            </div>
        `).join('');
    }

    function applyFilters() {
        const minLen = parseInt(document.getElementById('lenFilter').value) || 0;
        const limit = parseInt(document.getElementById('countLimit').value);
        
        let filtered = rawData.filter(d => d.seq_length >= minLen);
        filtered = filtered.slice(0, limit);
        renderCards(filtered);
    }

    // 初始化渲染
    if (rawData.length > 0) renderCards(rawData);
</script>

