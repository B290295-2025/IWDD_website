<?php
// 1. 联通数据库配置
require_once __DIR__ . '/../config/database.php';

// 初始化变量，确保全局可用
$output_data = [];
$error_message = "";
$debug_log = "No Python execution triggered.";
$taxon = $_POST["taxon"] ?? "";

// 2. 核心处理逻辑
if ($_SERVER["REQUEST_METHOD"] == "POST" && !empty($taxon)) {
    try {
        // 第一步：先查 SQL 数据库
        $stmt = $pdo->prepare("SELECT * FROM protein_data WHERE taxon_group = ?");
        $stmt->execute([$taxon]);
        $output_data = $stmt->fetchAll();

        // 第二步：如果数据库为空，则调用 Python 抓取
        if (empty($output_data)) {
            $python_exe = "/usr/bin/python3";
            $script_path = "/localdisk/home/s2845297/public_html/B290295_website/backend/fetch_protein.py";
            $edirect_path = "/home/s2845297/edirect";

            // 联通点：在命令中强行注入 EDirect 路径，解决 "efetch command not found"
            $cmd = "export PATH=\$PATH:$edirect_path; $python_exe $script_path " . escapeshellarg($taxon) . " 2>&1";
            
            $debug_log = shell_exec($cmd);

            if ($debug_log !== null && trim($debug_log) !== "") {
                $data = json_decode($debug_log, true);

                if ($data && !isset($data['error'])) {
                    // 第三步：PHP 负责处理入库
                    $ins = $pdo->prepare("INSERT IGNORE INTO protein_data 
                        (taxon_group, accession_id, description, sequence, seq_length) 
                        VALUES (?, ?, ?, ?, ?)");

                    foreach ($data as $p) {
                        $ins->execute([
                            $taxon,
                            $p['id'],
                            $p['description'],
                            $p['sequence'],
                            $p['length']
                        ]);
                    }
                    // 第四步：存完后重新读取，确保返回前端的数据格式统一
                    $stmt->execute([$taxon]);
                    $output_data = $stmt->fetchAll();
                } else {
                    $error_message = $data['error'] ?? "Python returned invalid JSON. Check debug log below.";
                }
            } else {
                $error_message = "Python script returned no output. Check permissions or paths.";
            }
        }
    } catch (PDOException $e) {
        $error_message = "Database Error: " . $e->getMessage();
    }
}
