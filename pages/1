// 3. 执行同步与查询逻辑
if ($taxon_filter !== '--select--' && $keyword_filter !== '--select--') {
    
    // 调用 Python 脚本从 NCBI 实时抓取
    $cmd_taxon = escapeshellarg($taxon_filter);
    $cmd_keyword = escapeshellarg($keyword_filter);
    $exec_path = "/usr/bin/python3 " . __DIR__ . "/../backend/fetch_protein.py $cmd_taxon $cmd_keyword 2>&1";
    shell_exec($exec_path);

    // SQL 匹配映射：确保能精确搜到刚抓取的数据
    $sql_map = [
        'glucose-6-phosphatase proteins' => '%glucose-6-phosphatase%',
        'ABC transporters'               => '%ABC transporter%',
        'kinases'                         => '%kinase%',
        'adenyl cyclases'                 => '%adenylyl cyclase%' // 适配 NCBI 的拼写
    ];
    $db_keyword = $sql_map[$keyword_filter] ?? '%' . $keyword_filter . '%';

    // 从数据库读取
    $sql = "SELECT * FROM protein_data WHERE taxon_group = ? AND description LIKE ? ORDER BY id DESC LIMIT 50";
    $stmt = $conn->prepare($sql);
    $stmt->execute([$taxon_filter, $db_keyword]);
    $data = $stmt->fetchAll(PDO::FETCH_ASSOC);
}
