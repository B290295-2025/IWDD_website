//Conservation Score//
function calc_conservation($msa) {

    $lines = explode("\n", $msa);
    $seqs = [];

    foreach ($lines as $line) {
        if (preg_match('/^(\S+)\s+([A-Z\-]+)/', $line, $m)) {
            $seqs[$m[1]] .= $m[2];
        }
    }

    $length = strlen(current($seqs));
    $scores = [];

    for ($i = 0; $i < $length; $i++) {
        $col = [];
        foreach ($seqs as $s) {
            $col[] = $s[$i] ?? '-';
        }
        $unique = array_unique($col);
        $scores[] = 1 - (count($unique) / count($col));
    }

    return $scores;
}
