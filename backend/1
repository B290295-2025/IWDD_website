def fetch_and_store(taxon, keyword):
    try:
        conn = mysql.connector.connect(**DB_CONFIG)
        cursor = conn.cursor()

        # ---------------------------------------------------------
        # 核心修改：构造与 NCBI 网页端一致的检索式
        # ---------------------------------------------------------
        # 将选项中的短语转换为 NCBI 接受的格式
        # 例如: "glucose-6-phosphatase proteins" -> "glucose 6 phosphatase proteins"
        ncbi_keyword = keyword.replace("-", " ")
        
        # 构造检索式: ("Aves"[Organism] OR Aves[All Fields]) AND keyword[All Fields]
        search_term = f'("{taxon}"[Organism] OR {taxon}[All Fields]) AND {ncbi_keyword}[All Fields]'
        
        print(f"DEBUG: Searching NCBI with: {search_term}", file=sys.stderr)

        # 执行 E-search
        handle = Entrez.esearch(db="protein", term=search_term, retmax=20)
        search_results = Entrez.read(handle)
        handle.close()

        id_list = search_results.get("IdList", [])
        if not id_list:
            print(f"DEBUG: No IDs found for {search_term}", file=sys.stderr)
            return

        # 执行 E-fetch
        handle = Entrez.efetch(db="protein", id=id_list, rettype="fasta", retmode="text")
        fasta_data = handle.read()
        handle.close()

        records = list(SeqIO.parse(io.StringIO(fasta_data), "fasta"))
        
        inserted_count = 0
        for record in records:
            accession = record.id.split('.')[0]
            description = record.description
            sequence = str(record.seq)
            seq_length = len(sequence)

            # 插入或更新，确保 taxon_group 记录的是传入的分类名
            query = """
            INSERT INTO protein_data (accession_id, description, seq_length, taxon_group, sequence)
            VALUES (%s, %s, %s, %s, %s)
            ON DUPLICATE KEY UPDATE 
                description = VALUES(description),
                seq_length = VALUES(seq_length),
                sequence = VALUES(sequence),
                taxon_group = VALUES(taxon_group)
            """
            cursor.execute(query, (accession, description, seq_length, taxon, sequence))
            inserted_count += 1

        conn.commit()
        cursor.close()
        conn.close()
        print(f"DEBUG: Successfully updated {inserted_count} records.", file=sys.stderr)

    except Exception as e:
        print(f"CRITICAL ERROR: {str(e)}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    if len(sys.argv) < 3:
        sys.exit(1)
    # 稍微休眠避开频率限制
    time.sleep(0.3)
    fetch_and_store(sys.argv[1], sys.argv[2])
