#!/usr/bin/env python3

import sys
import time
from Bio import Entrez

Entrez.email = "s2845297@ed.ac.uk"
Entrez.api_key = "da5f2b2bc8dfd014bbd15a6760b20c082608"

# ---------------------------
# 参数
# ---------------------------
if len(sys.argv) < 3:
    print("Error: Missing parameters")
    sys.exit(1)

taxon = sys.argv[1]
protein = sys.argv[2]

# ---------------------------
# 构建 query
# ---------------------------
query = f'({protein}[All Fields]) AND ({taxon}[All Fields])'

# 避免限速
time.sleep(1)

try:
    # Step 1: 搜索
    handle = Entrez.esearch(
        db="protein",
        term=query,
        retmax=10
    )
    record = Entrez.read(handle)
    handle.close()

    ids = record["IdList"]

    if not ids:
        print("Error: No sequences found")
        sys.exit(1)

    # Step 2: 获取 FASTA
    handle = Entrez.efetch(
        db="protein",
        id=",".join(ids),
        rettype="fasta",
        retmode="text"
    )

    fasta_data = handle.read()
    handle.close()

    print(fasta_data)

except Exception as e:
    print(f"Error: {str(e)}")
    sys.exit(1)
