<?php
require_once '../config/database.php'; // your PDO connection file

$dataDir = "../data/";
$files = ['aves_g6p.fasta', 'mammal_abc.fasta', 'rodent_kinase.fasta', 'vertebrate_ac.fasta'];

foreach ($files as $file) {
    if (!file_exists($dataDir . $file)) continue;

    $taxon_group = str_replace('.fasta', '', $file);
    $content = file_get_contents($dataDir . $file);
    
    // Simple FASTA Parser
    $entries = explode(">", $content);
    array_shift($entries); // Remove first empty element

    foreach ($entries as $entry) {
        $lines = explode("\n", $entry);
        $header = array_shift($lines); // First line is the description
        $sequence = implode("", $lines); // Rest is the sequence
        
        // Extract Accession ID from header (e.g., ">NP_001..." -> "NP_001")
        $accession = explode(" ", $header)[0];

        // Actioning SQL via PDO
        $sql = "INSERT INTO protein_data (taxon_group, accession_id, description, sequence, seq_length) 
                VALUES (?, ?, ?, ?, ?)
                ON DUPLICATE KEY UPDATE sequence=VALUES(sequence)";
        
        $stmt = $pdo->prepare($sql);
        $stmt->execute([$taxon_group, $accession, $header, $sequence, strlen($sequence)]);
    }
    echo "Imported $file successfully.\n";
}
?>
