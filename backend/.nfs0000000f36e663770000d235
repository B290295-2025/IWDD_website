#!/usr/bin/env python3
import sys
import subprocess
import json
import re

def fetch_via_edirect(taxon_key):
    """
    Executes Bash EDirect commands and returns parsed list of dicts.
    """
    # Map your dropdown values to NCBI search terms
    query_map = {
        "aves_g6p": "KAJ7421106.1,KAJ7396366.1,KAI6072612.1,KAI1230272.1,XP_040473657.1,XP_040392851.1,XP_039553177.1,XP_010411101.1,XP_027601652.2,XP_038019160.1",
        "mammal_abc": "Q9H8K7.2,KAF6316944.1,KAF6316942.1,KAF6107712.1,NP_001399719.1,3ZDQ_A,NP_001116146.1,NP_076221.1,NP_038482.3,NP_001020262.1",
        "rodent_kinase": "S43987,P61025.1,XP_080560003.1,XP_080546422.1,XP_078973293.1,KAM4874156.1,KAM4873688.1,XP_069870013.1,XP_081135560.1,XP_069870013.1",
        "vertebrate_ac": "QKE59411.1,CAC39962.1,CAN2389089.1,KAK2091232.1,CAH2273680.1,KAF5896945.1,ALO19545.1,ALO19543.1,CAA52282.1,1514117A"
    }
    ids = query_map.get(taxon_key, "")
    if not ids:
        return {"error": f"No fixed IDs found for: {taxon_key}"}
    ED_PATH = "/home/s2845297/edirect"
    ESEARCH = f"{ED_PATH}/esearch"
    EFETCH = f"{ED_PATH}/efetch"

    # Construct the Bash command: esearch | efetch
    # We use -format fasta to get the sequences
    bash_command = f"{EFETCH}-db protein -id '{ids}' -format fasta"
    
    try:
        # Run the bash command from Python
        process = subprocess.Popen(
                bash_command, 
                shell=True, 
                stdout=subprocess.PIPE, 
                stderr=subprocess.PIPE, 
                text=True)
        stdout, stderr = process.communicate()
        if not stdout:
            error_msg = stderr.strip() if stderr else "NCBI returned empty results (no match found)."
            return {"error": f"EDirect Failure: {error_msg}"}
        # Simple Regex Parser for FASTA (Manual parsing to avoid BioPython dependency)
        results = []
        entries = stdout.split(">")
        for entry in entries:
            hentry = entry.strip()
            if not entry:
                continue
                
            lines = entry.splitlines() # aotomatic process \n or \r\n
            if not lines:
                continue
            header = lines[0]
            sequence = "".join(lines[1:]).replace("","").upper()
            accession = header.split(" ")[0] if header else "Unknown"
            
            results.append({
                "id": accession,
                "description": header,
                "sequence": sequence,
                "length": len(sequence)
            })
            
        return results
    except Exception as e:
        # return the inside error
        return {"error": f"Internal Python Error: {str(e)}"}
    if __name__ == "__main__":
        # pretend charater error
        import sys
        import io
        sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')

        if len(sys.argv) < 2:
            print(json.dumps({"error": "No taxon provided"}))
            sys.exit(1)

        try:
            taxon_input = sys.argv[1]
            data = fetch_via_edirect(taxon_input)
        
            # check: why not obtain the fetch_file
            if data is None:
                print(json.dumps({"error": "fetch_via_edirect returned None"}))
            else:
                # only print this line, ensure php only got JSON format files.
                print(json.dumps(data))
        except Exception as fatal_e:
            print(json.dumps({"error": f"Fatal Script Error: {str(fatal_e)}"}))
